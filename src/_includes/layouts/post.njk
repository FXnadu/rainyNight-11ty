---
layout: layouts/base.njk
bodyClass: no-grid-page post-page
pageStyles:
  - /assets/css/alerts.css?v=20260211-1
  - /assets/css/code.css?v=20260211-1
  - /assets/css/pages/post.css?v=20260211-1
---

<article class="post-container">
    <header class="post-header">
        <h1 class="post-title">{{ title }}</h1>
        <div class="post-meta">
            <time datetime="{{ page.date }}" style="color: var(--text-secondary); display: inline-flex; align-items: center; gap: 8px;">
                <i class="fa-regular fa-calendar" aria-hidden="true" style="font-size: 0.95em; line-height: 1; transform: translateY(-1px);"></i>
                <span>{{ page.date | readableDate }}</span>
            </time>
            {% if updated %}
            <time datetime="{{ updated }}" style="color: var(--text-secondary); display: inline-flex; align-items: center; gap: 8px; margin-left: 16px;">
                <i class="fa-solid fa-pen-to-square" aria-hidden="true" style="font-size: 0.9em; line-height: 1; transform: translateY(-1px);"></i>
                <span>更新于 {{ updated | readableDate }}</span>
            </time>
            {% endif %}
        </div>
    </header>

    <details class="post-toc-mobile is-hidden">
        <summary>文章目录</summary>
        <ol class="post-toc-list" id="post-toc-mobile-list"></ol>
    </details>

    <nav class="post-toc post-toc-desktop is-hidden" aria-label="文章目录">
        <ol class="post-toc-list" id="post-toc-list"></ol>
    </nav>

    <div class="post-content">
        {{ content | safe }}
    </div>

    <div class="post-actions" aria-label="文章操作">
        <button class="post-action post-top" type="button" data-action="top" aria-label="返回顶部" title="返回顶部">
            <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
        </button>
        <button class="post-action post-back" type="button" data-action="back" aria-label="返回上页" title="返回上页">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        </button>
    </div>
</article>
