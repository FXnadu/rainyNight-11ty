<nav class="site-nav">
    <div class="logo">
        <a href="{{ siteConfig.brand.homeUrl | default('/') }}" style="text-decoration: none; color: inherit;">
            {{ siteConfig.brand.logoText | default('EcomInsight.dev') }}
        </a>
    </div>
    
    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-box">
            <span class="hamburger-inner"></span>
        </span>
    </button>

    <div class="menu-links">
        {% if siteConfig.navigation.main %}
            {% for item in siteConfig.navigation.main %}
            <a href="{{ item.url }}" data-nav="{{ item.url }}">
                {% if item.icon %}
                <svg width="18" height="18"><use href="#icon-{{ item.icon }}"/></svg>
                {% endif %}
                {{ item.text }}
            </a>
            {% endfor %}
        {% else %}
            <!-- Fallback links if config fails -->
            <a href="/"><svg width="18" height="18"><use href="#icon-home"/></svg>首页</a>
            <a href="/categories/"><svg width="18" height="18"><use href="#icon-folder"/></svg>知识库</a>
        {% endif %}
        
        <button class="theme-toggle" aria-label="Toggle dark theme">
            <svg class="icon-sun" width="20" height="20"><use href="#icon-sun"/></svg>
            <svg class="icon-moon" width="20" height="20"><use href="#icon-moon"/></svg>
        </button>
    </div>
    
    <div class="menu-overlay"></div>
</nav>
