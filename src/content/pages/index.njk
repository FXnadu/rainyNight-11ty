---
layout: layouts/base.njk
permalink: /
bodyClass: home-page
pageStyles:
  - /assets/css/pages/home.css
---
{% set homeConfig = siteConfig.pages.home %}

<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">{{ homeConfig.hero.title }}</h1>
        <p class="hero-subtitle">{{ homeConfig.hero.subtitle }}</p>
        
        <div class="hero-search" data-home-search>
            <form class="home-search-form" data-home-search-form>
                <div class="home-search-controls">
                    <input
                        id="home-search-input"
                        class="home-search-input"
                        type="search"
                        name="q"
                        placeholder="搜索知识库..."
                        autocomplete="off"
                        data-home-search-input
                    >
                    <button class="home-search-button" type="submit" aria-label="搜索">
                        <svg width="18" height="18"><use href="#icon-search"/></svg>
                    </button>
                </div>
            </form>
            <div class="home-search-results" data-home-search-results hidden></div>
        </div>
        
        <p class="hero-description">
            支持标题、分类、摘要和正文关键词检索，快速找到你需要的内容。<br>
            例如：福星抖音、福星淘宝、使用教程、安装指南...
        </p>
    </div>
</section>

<section class="section-block">
    <div class="section-header">
        <h2 class="section-title">{{ homeConfig.audience.title }}</h2>
    </div>
    <div class="who-for-grid">
        {% for item in homeConfig.audience.items %}
            {% set cardUrl = item.url | default('') %}
            {% if item.targetCategory %}
                {% set cardUrl = '/categories/#folder-' + (item.targetCategory | encodeSlug) %}
            {% endif %}
            {% if cardUrl %}
            <a href="{{ cardUrl }}" class="who-for-item who-for-link" style="text-decoration: none; color: inherit;">
            {% else %}
            <div class="who-for-item">
            {% endif %}
                <svg class="who-for-icon" width="24" height="24">
                    {%- if item.icon == "fa-solid fa-briefcase" -%}
                    <use href="#icon-briefcase"/>
                    {%- elif item.icon == "fa-solid fa-pen-nib" -%}
                    <use href="#icon-pen"/>
                    {%- elif item.icon == "fa-solid fa-camera-retro" -%}
                    <use href="#icon-camera"/>
                    {%- elif item.icon == "fa-solid fa-laptop-code" -%}
                    <use href="#icon-laptop"/>
                    {%- else -%}
                    <use href="#icon-file"/>
                    {%- endif -%}
                </svg>
                <div>
                    <h3 class="who-for-title">{{ item.title }}</h3>
                    <p class="who-for-desc">{{ item.description }}</p>
                </div>
            {% if cardUrl %}
            </a>
            {% else %}
            </div>
            {% endif %}
        {% endfor %}
    </div>
</section>

<section class="closing-block">
    <div class="closing-layout">
        <div>
            <span class="closing-label">{{ homeConfig.closing.label }}</span>
            <h2 class="closing-headline">{{ homeConfig.closing.headline | nl2br | safe }}</h2>
        </div>
        <div class="closing-content">
            <p class="closing-desc">{{ homeConfig.closing.description }}</p>
            <a href="{{ homeConfig.closing.actionUrl }}" class="closing-link">
                {{ homeConfig.closing.actionText }}
                <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
    </div>
</section>
