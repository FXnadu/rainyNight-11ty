---
layout: layouts/base.njk
permalink: /link-converter/
bodyClass: link-converter-page
pageStyles:
  - /assets/css/pages/link-converter.css
---

<div class="converter-page-container">
    <div class="converter-layout">
        <!-- 侧边 Tab 栏 -->
        <aside class="converter-sidebar">
            <nav class="sidebar-nav">
                <button class="sidebar-tab active" data-tab="douyin">
                    <svg class="tab-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                    </svg>
                    <span class="tab-label">抖音转链</span>
                </button>
                <button class="sidebar-tab" data-tab="taobao">
                    <i data-lucide="shopping-bag" class="tab-icon" style="width: 20px; height: 20px;"></i>
                    <span class="tab-label">淘宝简链</span>
                </button>
            </nav>

            <div class="sidebar-tips">
                <h4>使用说明</h4>
                <div class="tips-content" data-tips="douyin">
                    <ul>
                        <li>支持抖音口令和带 alkey 的长链接</li>
                        <li>每条链接单独占一行</li>
                        <li>支持批量转换</li>
                    </ul>
                </div>
                <div class="tips-content hidden" data-tips="taobao">
                    <ul>
                        <li>支持淘宝/天猫商品链接</li>
                        <li>自动提取商品ID</li>
                        <li>生成简洁链接便于分享</li>
                    </ul>
                </div>
            </div>
        </aside>

        <!-- 抖音转链面板 -->
        <div class="content-panel active" data-panel="douyin">
            <div class="panel-header">
                <h2>抖音转链</h2>
                <p class="panel-desc">支持识别【抖音口令】和【带alkey的长链接】两种格式</p>
            </div>
            
            <textarea id="douyin-input" class="converter-input" placeholder="请在这里粘贴【抖音口令】或【带alkey参数的长链接】，每条占一行..."></textarea>
            
            <div class="converter-controls">
                <button id="douyin-convert-btn" class="converter-btn converter-btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
                    </svg>
                    智能转换
                </button>
                <button id="douyin-clear-btn" class="converter-btn converter-btn-secondary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    清空内容
                </button>
            </div>

            <div id="douyin-status" class="converter-status"></div>
            
            <div id="douyin-results" class="converter-results">
                <p class="converter-results-placeholder">转换结果将显示在这里...</p>
            </div>
        </div>

        <!-- 淘宝简链面板 -->
        <div class="content-panel" data-panel="taobao">
            <div class="panel-header">
                <h2>淘宝简链</h2>
                <p class="panel-desc">提取淘宝/天猫长链接中的商品ID，生成简洁的商品链接</p>
            </div>
            
            <textarea id="taobao-input" class="converter-input" placeholder="请在这里粘贴【淘宝商品链接】或【天猫商品链接】，每条占一行..."></textarea>
            
            <div class="converter-controls">
                <button id="taobao-convert-btn" class="converter-btn converter-btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    简化链接
                </button>
                <button id="taobao-clear-btn" class="converter-btn converter-btn-secondary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    清空内容
                </button>
            </div>

            <div id="taobao-status" class="converter-status"></div>
            
            <div id="taobao-results" class="converter-results">
                <p class="converter-results-placeholder">简化结果将显示在这里...</p>
            </div>
        </div>
    </div>
</div>

<script>
    // ==================== 抖音转链功能 ====================
    const CORS_PROXY = 'https://api.allorigins.win/get?url=';
    const douyinInput = document.getElementById('douyin-input');
    const douyinConvertBtn = document.getElementById('douyin-convert-btn');
    const douyinClearBtn = document.getElementById('douyin-clear-btn');
    const douyinStatus = document.getElementById('douyin-status');
    const douyinResults = document.getElementById('douyin-results');

    function parseAlkeyAndBuildUrl(urlString) {
        try {
            const decodedUrlString = decodeURIComponent(urlString);
            const url = new URL(decodedUrlString);
            const alkeyValue = url.searchParams.get('alkey');
            
            if (!alkeyValue) {
                return '错误：链接中缺少 alkey 参数。<div class="error-suggestion">提示：请尝试在浏览器新标签页中打开口令里的短链接，然后将跳转后的完整网址粘贴回来进行转换。</div>';
            }

            const alkeyParts = alkeyValue.split('_');
            if (alkeyParts.length < 4) {
                return `错误：alkey 参数格式不正确 (${alkeyValue})。`;
            }
            const productId = alkeyParts[3];

            return `https://haohuo.jinritemai.com/ecommerce/trade/detail/index.html?id=${productId}&origin_type=604#/`;
        } catch (error) {
            return `错误：解析URL失败 (${error.message})。`;
        }
    }

    async function convertDouyinInput(inputString) {
        if (inputString.includes('haohuo.jinritemai.com') && inputString.includes('alkey=')) {
            return parseAlkeyAndBuildUrl(inputString);
        }

        const shortUrlMatch = inputString.match(/https?:\/\/v\.douyin\.com\/[^\s]+/);
        if (shortUrlMatch) {
            const shortUrl = shortUrlMatch[0];
            try {
                const response = await fetch(CORS_PROXY + encodeURIComponent(shortUrl));
                if (!response.ok) {
                    return `错误：访问短链接失败 (状态码: ${response.status})。`;
                }
                const data = await response.json();
                const intermediateUrl = data.status.url;

                if (!intermediateUrl) {
                    return '错误：代理未能返回最终跳转链接。';
                }
                
                return parseAlkeyAndBuildUrl(intermediateUrl);
            } catch (error) {
                return `错误：网络或代理请求失败 (${error.message})。`;
            }
        }
        
        return '错误：无法识别的格式。请输入抖音口令或带alkey参数的长链接。';
    }

    async function handleDouyinBatchConvert() {
        const inputs = douyinInput.value.split('\n').filter(line => line.trim() !== '');
        if (inputs.length === 0) {
            douyinStatus.textContent = '请输入至少一条内容！';
            return;
        }

        douyinResults.innerHTML = '';
        douyinStatus.textContent = '正在初始化...';
        douyinConvertBtn.disabled = true;

        for (let i = 0; i < inputs.length; i++) {
            const input = inputs[i];
            douyinStatus.textContent = `处理中... (${i + 1}/${inputs.length})`;
            const result = await convertDouyinInput(input);
            displayResult(douyinResults, input, result);
        }
        
        douyinStatus.textContent = `处理完成！共 ${inputs.length} 条。`;
        douyinConvertBtn.disabled = false;
    }

    douyinConvertBtn.addEventListener('click', handleDouyinBatchConvert);
    douyinClearBtn.addEventListener('click', () => {
        douyinInput.value = '';
        douyinResults.innerHTML = '<p class="converter-results-placeholder">转换结果将显示在这里...</p>';
        douyinStatus.textContent = '';
    });

    // ==================== 淘宝简链功能 ====================
    const taobaoInput = document.getElementById('taobao-input');
    const taobaoConvertBtn = document.getElementById('taobao-convert-btn');
    const taobaoClearBtn = document.getElementById('taobao-clear-btn');
    const taobaoStatus = document.getElementById('taobao-status');
    const taobaoResults = document.getElementById('taobao-results');

    function simplifyTaobaoUrl(urlString) {
        try {
            const idMatch = urlString.match(/[?&](?:id|itemId)=(\d+)/);
            if (!idMatch) {
                return '错误：无法从链接中提取商品ID。请检查链接格式是否正确。';
            }
            
            const itemId = idMatch[1];
            
            if (urlString.includes('tmall.com') || urlString.includes('detail.tmall.com')) {
                return `https://detail.tmall.com/item.htm?id=${itemId}`;
            } else {
                return `https://item.taobao.com/item.htm?id=${itemId}`;
            }
        } catch (error) {
            return `错误：解析链接失败 (${error.message})。`;
        }
    }

    function handleTaobaoBatchConvert() {
        const inputs = taobaoInput.value.split('\n').filter(line => line.trim() !== '');
        if (inputs.length === 0) {
            taobaoStatus.textContent = '请输入至少一条内容！';
            return;
        }

        taobaoResults.innerHTML = '';
        taobaoStatus.textContent = '正在处理...';
        taobaoConvertBtn.disabled = true;

        for (let i = 0; i < inputs.length; i++) {
            const input = inputs[i];
            const result = simplifyTaobaoUrl(input);
            displayResult(taobaoResults, input, result);
        }
        
        taobaoStatus.textContent = `处理完成！共 ${inputs.length} 条。`;
        taobaoConvertBtn.disabled = false;
    }

    taobaoConvertBtn.addEventListener('click', handleTaobaoBatchConvert);
    taobaoClearBtn.addEventListener('click', () => {
        taobaoInput.value = '';
        taobaoResults.innerHTML = '<p class="converter-results-placeholder">简化结果将显示在这里...</p>';
        taobaoStatus.textContent = '';
    });

    // ==================== 通用显示函数 ====================
    function displayResult(container, original, result) {
        const itemDiv = document.createElement('div');
        itemDiv.className = 'result-item';

        const originalP = document.createElement('div');
        originalP.className = 'original-command';
        originalP.textContent = `原始输入: ${original}`;
        
        const resultP = document.createElement('div');
        if (result && result.startsWith('http')) {
            resultP.innerHTML = `转换结果: <a href="${result}" target="_blank" class="final-link">${result}</a>`;
        } else {
            resultP.innerHTML = `转换结果: <span class="error-link">${result}</span>`;
        }
        
        itemDiv.appendChild(originalP);
        itemDiv.appendChild(resultP);
        container.appendChild(itemDiv);
    }

    // 初始化 Lucide 图标
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>
